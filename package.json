{
  "name": "3dil-routeros-monorepo",
  "private": true,
  "version": "2.0.0-alpha.3",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm run -w shared build && npm run -w frontend build && npm run -w backend build",
    "typecheck": "npm run -w shared typecheck && npm run -w backend typecheck && npm run -w frontend typecheck",
    "lint": "npm run -w shared lint && npm run -w backend lint && npm run -w frontend lint",
    "test": "echo \"No tests configured\""
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.0.1",
    "eslint": "^9.14.0",
    "globals": "^15.6.0",
    "typescript": "^5.8.3"
  }
}
